# Qwen Medical Transcriber - Конфигурация
# Скопируйте этот файл в .env и настройте параметры

# HF_TOKEN не требуется при локальных моделях
# Оставьте пустым, если модели находятся в папке ./models
HF_TOKEN=

# Порты для Web UI
GRADIO_PORT=7860
GRADIO_SHARE=false

# Настройки логирования
LOG_LEVEL=INFO
LOG_DIR=./logs

# Настройки аудио
TARGET_SAMPLE_RATE=16000
TARGET_CHANNELS=1
TARGET_FORMAT=wav
TARGET_SUBTYPE=PCM_16
TARGET_RMS=-20

# Настройки диаризации
DEFAULT_NUM_SPEAKERS=2
MIN_SPEAKERS=1
MAX_SPEAKERS=5

# Настройки языка
SUPPORTED_LANGUAGES=ru, en
DEFAULT_LANGUAGE=ru

# Настройки output
OUTPUT_DIR=./output
UPLOADS_DIR=./uploads
CONVERTED_DIR=./uploads/converted

# Настройки моделей
MODELS_DIR=./models
ASR_MODEL_PATH=./models/Qwen3-ASR-1.7B
ALIGNER_MODEL_PATH=./models/Qwen3-ForcedAligner-0.6B
DIARIZATION_MODEL_PATH=./models/pyannote-speaker-diarization-3.1
